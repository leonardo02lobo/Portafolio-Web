<header class="bg-navbar text-white px-16 py-6 flex flex-col justify-center items-start">
    <nav>
        <li class="list-none text-xl flex gap-8">
            <a href="/" class="hover:text-cyan-button transition-colors duration-300">INICIO</a>
            <a href="#sobremi" class="hover:text-cyan-button transition-colors duration-300">SOBRE MI</a>
            <a href="#projects" class="hover:text-cyan-button transition-colors duration-300">PROYECTOS</a>
            <a href="#skills" class="hover:text-cyan-button transition-colors duration-300">HABILIDADES</a>
        </li>
    </nav>
</header>
<script is:inline>
    const initMobileMenu = () => {
        const header = document.querySelector('header');
        const nav = header?.querySelector('nav');
        const list = nav?.querySelector('li');
        if (!header || !nav || !list) return;

        nav.classList.add('w-full', 'md:w-auto');
        list.classList.add(
            'hidden',
            'md:flex',
            'flex-col',
            'md:flex-row',
            'w-full',
            'md:w-auto',
            'mt-4',
            'md:mt-0',
            'gap-4',
            'md:gap-8',
            'text-lg',
            'md:text-xl'
        );

        const button = document.createElement('button');
        button.type = 'button';
        button.className =
            'md:hidden inline-flex items-center justify-center p-2 rounded text-white hover:text-cyan-button transition-colors duration-300';
        button.setAttribute('aria-label', 'Abrir menú');
        button.setAttribute('aria-expanded', 'false');
        button.innerHTML = `
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
        `;

        button.addEventListener('click', () => {
            const isOpen = button.getAttribute('aria-expanded') === 'true';
            list.classList.toggle('hidden', isOpen);
            list.classList.toggle('flex', !isOpen);
            button.setAttribute('aria-expanded', String(!isOpen));
            button.setAttribute('aria-label', !isOpen ? 'Cerrar menú' : 'Abrir menú');
        });

        header.insertBefore(button, nav);

        const syncByScreen = () => {
            if (window.innerWidth >= 768) {
                list.classList.remove('hidden');
                list.classList.add('flex');
                button.setAttribute('aria-expanded', 'false');
            } else if (button.getAttribute('aria-expanded') === 'false') {
                list.classList.add('hidden');
                list.classList.remove('flex');
            }
        };

        syncByScreen();
        window.addEventListener('resize', syncByScreen);
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileMenu);
    } else {
        initMobileMenu();
    }
</script>