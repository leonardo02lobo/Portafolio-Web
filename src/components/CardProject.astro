---
interface Props {
    title: string;
    description: string;
    imageUrl: string;
    projectUrl: string;
    skills: string[];
}

const { title, description, imageUrl, projectUrl, skills } = Astro.props as Props;
---

<article class="flex flex-col justify-between max-w-md rounded-2xl border border-white/10 bg-white/5 p-6 text-white backdrop-blur-sm transition hover:border-cyan-400/50 hover:shadow-lg hover:shadow-cyan-500/10 hover:-translate-y-3">
    <div class="flex items-center gap-4">
        <img
            src={imageUrl}
            alt={title}
            class="h-14 w-14 rounded-xl object-cover ring-1 ring-white/20"
        />
        <h3 class="text-2xl font-semibold tracking-tight">{title}</h3>
    </div>

    <p class="mt-4 text-sm leading-relaxed text-white/80">
        {description}
    </p>

    <ul class="mt-4 flex flex-wrap gap-2">
        {skills.map((skill) => (
            <li class="rounded-full border border-white/15 px-3 py-1 text-xs text-white/80">
                {skill}
            </li>
        ))}
    </ul>

    <a
        href={projectUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-5 inline-flex items-center text-sm font-medium text-cyan-300 transition hover:text-cyan-200"
    >
        Ver proyecto →
    </a>
</article>