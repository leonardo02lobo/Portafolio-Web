---
import Java from "./icons/Java.astro";
import KaliLinux from "./icons/KaliLinux.astro";
import Python from "./icons/Python.astro";
---

<div class="mx-auto mt-8 w-full max-w-3xl">
    <div class="mx-auto flex w-full max-w-2xl flex-col gap-10 pl-6 sm:pl-8">
        <article class="flex items-start gap-4">
            <div
                class="-ml-[2.125rem] mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-cyan-button bg-secondary-background text-xl"
            >
                <span class="text-cyan-button">🏛️</span>
            </div>

            <div class="min-w-0 flex-1 space-y-2 pt-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <span class="block min-w-0 break-words text-white text-lg font-bold uppercase leading-tight">
                        INICIO UNET
                    </span>
                    <span class="text-cyan-button text-sm">2022</span>
                </div>
            </div>
        </article>

        <article class="flex items-start gap-4">
            <div
                class="-ml-[2.125rem] mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-cyan-button bg-secondary-background text-xl"
            >
                <span class="text-cyan-button">👨‍💻</span>
            </div>

            <div class="min-w-0 flex-1 space-y-3 pt-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <span class="block min-w-0 break-words text-white text-lg font-bold uppercase leading-tight">
                        DESARROLLO FULL-STACK
                    </span>
                    <span class="text-cyan-button text-sm">2024</span>
                </div>
                <div
                    class="inline-flex items-center gap-2 rounded-full bg-secondary-background px-3 py-1 text-xs text-white ring-1 ring-cyan-button/35"
                >
                    <Java class="h-4 w-4" />
                    <span>Java</span>
                </div>
            </div>
        </article>

        <article class="flex items-start gap-4">
            <div
                class="-ml-[2.125rem] mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-cyan-button bg-secondary-background text-xl"
            >
                <span class="text-cyan-button">⚙️</span>
            </div>

            <div class="min-w-0 flex-1 space-y-3 pt-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                    <span class="block min-w-0 break-words text-white text-lg font-bold uppercase leading-tight">
                        ENFOQUE: CIBERSEGURIDAD & IA
                    </span>
                    <span class="text-cyan-button text-sm">2025</span>
                </div>
                <div
                    class="inline-flex items-center gap-2 rounded-full bg-secondary-background px-3 py-1 text-xs text-white ring-1 ring-cyan-button/35"
                >
                    <Python class="h-4 w-4" />
                    <span>Python</span>
                </div>
            </div>
        </article>

        <article class="flex items-start gap-4">
            <div
                class="-ml-[2.125rem] mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border-2 border-cyan-button bg-secondary-background text-xl"
            >
                <span class="text-cyan-button">🏆</span>
            </div>

            <div class="min-w-0 flex-1 space-y-3 pt-1">
                <span class="block min-w-0 break-words text-white text-lg font-bold uppercase tracking-wider leading-tight">
                    META: LIDERAZGO TÉCNICO
                </span>
                <div
                    class="inline-flex items-center gap-2 rounded-full bg-secondary-background px-3 py-1 text-xs text-white ring-1 ring-cyan-button/35"
                >
                    <KaliLinux class="h-4 w-4" />
                    <span>Kali Linux</span>
                </div>
            </div>
        </article>
    </div>
</div>
